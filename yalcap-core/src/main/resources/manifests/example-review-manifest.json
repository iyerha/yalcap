{
  "id": "example-review",
  "title": "Example Review Workflow",
  "version": "1.0.0",
  "dataSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
      "applicantName": { "type": "string" },
      "amount": { "type": "number" },
      "notes": { "type": "string" }
    },
    "required": ["applicantName","amount"]
  },
  "controlSchema": {
    "layout": [{ "pointer": "#/properties/applicantName", "widget": "text" }, { "pointer": "#/properties/amount", "widget": "number" }, { "pointer": "#/properties/notes", "widget": "textarea" }]
  },
  "steps": [
    {
      "id": "submit",
      "title": "Submit",
      "uiPointer": "#/control/submit",
      "allowedGroups": ["requestor"],
      "assignmentMode": "first-wins",
      "multiInstance": false,
      "transitions": { "onSubmit": "review" }
    },
    {
      "id": "review",
      "title": "Review",
      "uiPointer": "#/control/review",
      "allowedGroups": ["finance","audit"],
      "allowedUsers": ["alice","bob"],
      "assignmentMode": "parallel",
      "multiInstance": true,
      "transitions": { "onApprove": "approved", "onReject": "submit" }
    },
    {
      "id": "approved",
      "title": "Approved",
      "uiPointer": "#/control/approved",
      "allowedGroups": ["system"],
      "multiInstance": false
    }
  ]
}
